{
  "name": "lumi-app-finder-mcp",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "First-party MCP app finder for 28 Lumi Studio iOS apps across 50 Apple locales",
  "scripts": {
    "sync:catalog": "node scripts/sync-catalog.mjs",
    "test": "node --test",
    "validate": "mcpb validate manifest.json",
    "pack:mcpb": "mcpb validate manifest.json && python3 scripts/pack_bundle.py"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "stopword": "3.1.5"
  }
}
