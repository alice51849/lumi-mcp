{
  "name": "lumi-app-finder-mcp",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "First-party MCP app finder for 28 Lumi Studio iOS apps across 50 Apple locales",
  "files": [
    "server/index.mjs",
    "server/catalog.json",
    "ui/app-finder.html",
    "MCP_APP_NOTICES.txt",
    "THIRD_PARTY_NOTICES.txt",
    "PRIVACY.md"
  ],
  "scripts": {
    "build:ui": "node scripts/build-ui.mjs",
    "build:skill": "node scripts/build-skill-catalog.mjs",
    "sync:catalog": "node scripts/sync-catalog.mjs && node scripts/build-skill-catalog.mjs",
    "test": "node scripts/build-skill-catalog.mjs --check && node scripts/build-ui.mjs --check && node --test",
    "validate": "mcpb validate manifest.json",
    "pack:mcpb": "node scripts/build-ui.mjs --check && mcpb validate manifest.json && python3 scripts/pack_bundle.py"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "esbuild": "0.28.1",
    "stopword": "3.1.5"
  },
  "bin": {
    "lumi-app-finder": "server/index.mjs"
  }
}
